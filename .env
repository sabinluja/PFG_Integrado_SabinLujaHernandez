COMPOSE_PROJECT_NAME=trueconnector

# DB AES PASSWORD
AES_SECRET_KEY=mySecretKey1234567890123456

# ---------------------------------------------------------------------------
# BROKER — apunta al Broker IDS local (ids-broker, levantado en docker-compose)
# En producción: https://broker.ids.isst.fraunhofer.de/infrastructure
# ---------------------------------------------------------------------------
BROKER_URL=https://broker-reverseproxy/infrastructure

# TLS
KEYSTORE_NAME=ssl-server.jks
KEY_PASSWORD=changeit
KEYSTORE_PASSWORD=changeit
ALIAS=execution-core-container

TRUSTORE_NAME=truststoreEcc.jks
TRUSTORE_PASSWORD=allpassword

# ---------------------------------------------------------------------------
# DAPS — token caching activado y fetch en arranque para Omejdn local
# Los ECCs apuntan a Omejdn a través de nginx (container "omejdn"):
#   application.dapsUrl     = https://omejdn/auth/token
#   application.dapsJWKSUrl = https://omejdn/auth/jwks.json
# (configurado en application-docker.properties, no aquí)
# ---------------------------------------------------------------------------
CACHE_TOKEN=true
FETCH_TOKEN_ON_STARTUP=true

MULTIPART_ECC=form
WS_ECC=false
IDSCP2=false

EXTRACT_PAYLOAD_FROM_RESPONSE=true
VALIDATE_SELF_DESCRIPTION=false

# ---------------------------------------------------------------------------
# WORKER 1
# ---------------------------------------------------------------------------
WORKER1_PORT=8090
WORKER1_MULTIPART_EDGE=form
WORKER1_DATA_APP_ENDPOINT=https://be-dataapp-worker1:8500/data
WORKER1_WS_EDGE=false
WORKER1_ISSUER_CONNECTOR_URI=http://w3id.org/engrd/connector/worker1
WORKER1_ECC_FIREWALL=true
# Keystore DAPS para worker1 — fichero P12 registrado en Omejdn
# Ruta relativa a ./certs/ (montado en /cert/ dentro del ECC)
WORKER1_DAPS_KEYSTORE_NAME=worker1-daps.p12
WORKER1_DAPS_KEYSTORE_PASSWORD=ids2024
WORKER1_DAPS_KEYSTORE_ALIAS=worker1
# UUID del conector — debe coincidir con client_id en omejdn/config/clients.yml
WORKER1_CONNECTOR_UUID=9D:C5:9B:DB:06:DA:FC:E1:0D:07:A7:FF:65:CB:2C:84:9F:2F:78:87:keyid:C4:76:D0:AA:CD:93:79:35:0F:EB:A7:64:60:90:A4:6B:B4:38:4D:33
WORKER1_DEFAULT_ENDPOINT=https://ecc-worker1:8449/api/ids/data

