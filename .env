COMPOSE_PROJECT_NAME=trueconnector

# DB AES PASSWORD
AES_SECRET_KEY=mySecretKey1234567890123456

BROKER_URL=https://broker.ids.isst.fraunhofer.de/infrastructure

# TLS
KEYSTORE_NAME=ssl-server.jks
KEY_PASSWORD=changeit
KEYSTORE_PASSWORD=changeit
ALIAS=execution-core-container

TRUSTORE_NAME=truststoreEcc.jks
TRUSTORE_PASSWORD=allpassword

CACHE_TOKEN=false
FETCH_TOKEN_ON_STARTUP=false

MULTIPART_ECC=form
WS_ECC=false
IDSCP2=false

EXTRACT_PAYLOAD_FROM_RESPONSE=true
VALIDATE_SELF_DESCRIPTION=false

# Parámetros FL — usados por los 3 workers
FL_ROUNDS=5
ROUND_TIMEOUT=180

# ---------------------------------------------------------------------------
# WORKER 1
# Puerto 5001 host → :8500 container  (/proxy para Postman + /data para ECC)
# ---------------------------------------------------------------------------
WORKER1_PORT=8090
WORKER1_MULTIPART_EDGE=form
WORKER1_DATA_APP_ENDPOINT=https://be-dataapp-worker1:8500/data
WORKER1_WS_EDGE=false
WORKER1_ISSUER_CONNECTOR_URI=http://w3id.org/engrd/connector/worker1
WORKER1_ECC_FIREWALL=true
WORKER1_DAPS_KEYSTORE_NAME=
WORKER1_DAPS_KEYSTORE_PASSWORD=
WORKER1_DAPS_KEYSTORE_ALIAS=

# ---------------------------------------------------------------------------
# WORKER 2
# Puerto 5002 host → :8500 container
# ---------------------------------------------------------------------------
WORKER2_PORT=8092
WORKER2_MULTIPART_EDGE=form
WORKER2_DATA_APP_ENDPOINT=https://be-dataapp-worker2:8500/data
WORKER2_WS_EDGE=false
WORKER2_ISSUER_CONNECTOR_URI=http://w3id.org/engrd/connector/worker2
WORKER2_ECC_FIREWALL=true
WORKER2_DAPS_KEYSTORE_NAME=
WORKER2_DAPS_KEYSTORE_PASSWORD=
WORKER2_DAPS_KEYSTORE_ALIAS=

# ---------------------------------------------------------------------------
# WORKER 3
# Puerto 5003 host → :8500 container
# ---------------------------------------------------------------------------
WORKER3_PORT=8093
WORKER3_MULTIPART_EDGE=form
WORKER3_DATA_APP_ENDPOINT=https://be-dataapp-worker3:8500/data
WORKER3_WS_EDGE=false
WORKER3_ISSUER_CONNECTOR_URI=http://w3id.org/engrd/connector/worker3
WORKER3_ECC_FIREWALL=true
WORKER3_DAPS_KEYSTORE_NAME=
WORKER3_DAPS_KEYSTORE_PASSWORD=
WORKER3_DAPS_KEYSTORE_ALIAS=