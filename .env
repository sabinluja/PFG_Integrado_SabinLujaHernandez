# ---------------------------------------------------------------------------
# WORKER 4 (sin acceso al modelo FL — conector IDS legítimo, rechazado en FL)
# ---------------------------------------------------------------------------
WORKER4_PORT=8094
WORKER4_MULTIPART_EDGE=form
WORKER4_DATA_APP_ENDPOINT=https://be-dataapp-worker4:8500/data
WORKER4_WS_EDGE=false
WORKER4_ISSUER_CONNECTOR_URI=http://w3id.org/engrd/connector/worker4
WORKER4_ECC_FIREWALL=true
