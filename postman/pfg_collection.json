  "item": [
    {
      "name": " FL Algorithm Deployment Flow",
      "item": [
        {
          "name": "1 - IDS: Description Request (Self-Description del Worker-2)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Self-description válida con resourceCatalog', () => {",
                  "    const raw = pm.response.text();",
                  "",
                  "    // Intentar parsear como JSON puro primero",
                  "    let sd = null;",
                  "    try { sd = JSON.parse(raw); } catch(e) {}",
                  "",
                  "    // Si no, buscar el bloque JSON más grande dentro del multipart",
                  "    if (!sd) {",
                  "        const matches = raw.match(/\\{[\\s\\S]+\\}/g);",
                  "        if (matches) {",
                  "            for (const m of matches.reverse()) {",
                  "                try { const o = JSON.parse(m); if (o['ids:resourceCatalog']) { sd = o; break; } } catch(e) {}",
                  "            }",
                  "        }",
                  "    }",
                  "",
                  "    pm.expect(sd).to.exist;",
                  "    pm.expect(sd).to.have.property('ids:resourceCatalog');",
                  "",
                  "    const catalog   = sd['ids:resourceCatalog'];",
                  "    pm.expect(catalog).to.be.an('array').with.length.above(0);",
                  "",
                  "    const resources = catalog[0]['ids:offeredResource'] || [];",
                  "    pm.expect(resources.length).to.be.above(0, 'No hay offeredResource en el catálogo');",
                  "",
                  "    const resource = resources[0];",
                  "    pm.environment.set('offered_resource', resource['@id'] || '');",
                  "    console.log('✅ offered_resource:', resource['@id']);",
                  "",
                  "    // ── Contrato ─────────────────────────────────────────────────────────",
                  "    const contracts = resource['ids:contractOffer'] || [];",
                  "    pm.expect(contracts.length).to.be.above(0, 'No hay contractOffer en el recurso');",
                  "    const c = contracts[0];",
                  "    const cid = c['@id'] || '';",
                  "    pm.environment.set('contract_id', cid);",
                  "    pm.environment.set('contract_provider', (c['ids:provider'] || {'@id':''})['@id'] || '');",
                  "    const perms = c['ids:permission'] || [];",
                  "    pm.environment.set('contract_permission', perms.length > 0 ? JSON.stringify(perms[0]) : '{}');",
                  "    console.log('✅ contract_id:', cid);",
                  "    console.log('✅ contract_provider:', (c['ids:provider'] || {'@id':''})['@id']);",
                  "",
                  "    // ── Artifact ─────────────────────────────────────────────────────────",
                  "    const reprs = resource['ids:representation'] || [];",
                  "    if (reprs.length > 0) {",
                  "        const inst = (reprs[0]['ids:instance'] || [])[0];",
                  "        if (inst && inst['@id']) {",
                  "            pm.environment.set('contract_artifact', inst['@id']);",
                  "            console.log('✅ contract_artifact:', inst['@id']);",
                  "        } else {",
                  "            console.log('⚠️  ids:instance no encontrado — contract_artifact NO actualizado');",
                  "        }",
                  "    } else {",
                  "        console.log('⚠️  ids:representation vacío — contract_artifact NO actualizado');",
                  "    }",
                  "",
                  "    // ── Guardar la self-description completa para debug ───────────────────",
                  "    pm.environment.set('_sd_raw', JSON.stringify(sd).substring(0, 2000));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "idsUser",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "passwordIdsUser",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"multipart\": \"{{multipart_type}}\",\n    \"Forward-To\": \"{{Forward-To}}\",\n    \"messageType\": \"DescriptionRequestMessage\"\n}"
            },
            "url": {
              "raw": "{{Proxy_Endpoint}}",
              "host": [
                "{{Proxy_Endpoint}}"
              ]
            },
            "description": "Obtiene la Self-Description del worker destino (ecc-worker2). Extrae automáticamente offered_resource, contract_id, contract_provider, contract_permission, contract_artifact."
          },
          "response": []
        },
        {
          "name": "2 - IDS: Description Request (con Offered Resource)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Detalle del recurso recibido\", () => {",
                  "    pm.expect(pm.response.json()).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "idsUser",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "passwordIdsUser",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"multipart\": \"{{multipart_type}}\",\n    \"Forward-To\": \"{{Forward-To}}\",\n    \"messageType\": \"DescriptionRequestMessage\",\n    \"requestedElement\": \"{{offered_resource}}\"\n}"
            },
            "url": {
              "raw": "{{Proxy_Endpoint}}",
              "host": [
                "{{Proxy_Endpoint}}"
              ]
            },
            "description": "Obtiene información detallada sobre el recurso específico (offered_resource). Opcional pero útil para confirmar el artifact ID y las condiciones del contrato."
          },
          "response": []
        },
        {
          "name": "3 - IDS: Contract Request Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('ContractAgreement recibido', () => {",
                  "    const body = pm.response.text();",
                  "    pm.expect(body).to.satisfy(b => b.includes('ContractAgreement') || b.includes('@id'));",
                  "});",
                  "",
                  "// ── Extracción robusta del @id del ContractAgreement ─────────────────────",
                  "// La respuesta puede llegar como JSON puro O dentro de un multipart.",
                  "// Probamos ambas formas para asegurarnos de guardar transfer_contract.",
                  "(function extractAgreement() {",
                  "    const raw = pm.response.text();",
                  "    let agreement = null;",
                  "",
                  "    // Intento 1: JSON puro",
                  "    try {",
                  "        const j = JSON.parse(raw);",
                  "        if (j['@id']) { agreement = j; }",
                  "    } catch(e) {}",
                  "",
                  "    // Intento 2: multipart — buscar todos los bloques JSON y quedarnos",
                  "    // con el que tenga @type ContractAgreement",
                  "    if (!agreement) {",
                  "        const blocks = raw.match(/\\{[\\s\\S]*?\\}/g) || [];",
                  "        // de mayor a menor longitud para coger el más completo",
                  "        blocks.sort((a, b) => b.length - a.length);",
                  "        for (const b of blocks) {",
                  "            try {",
                  "                const o = JSON.parse(b);",
                  "                if (o['@id'] && o['@type'] && String(o['@type']).includes('ContractAgreement')) {",
                  "                    agreement = o; break;",
                  "                }",
                  "            } catch(e) {}",
                  "        }",
                  "    }",
                  "",
                  "    // Intento 3: cualquier objeto con @id si no encontramos ContractAgreement",
                  "    if (!agreement) {",
                  "        const blocks = raw.match(/\\{[\\s\\S]*?\\}/g) || [];",
                  "        blocks.sort((a, b) => b.length - a.length);",
                  "        for (const b of blocks) {",
                  "            try {",
                  "                const o = JSON.parse(b);",
                  "                if (o['@id']) { agreement = o; break; }",
                  "            } catch(e) {}",
                  "        }",
                  "    }",
                  "",
                  "    if (agreement && agreement['@id']) {",
                  "        pm.environment.set('transfer_contract', agreement['@id']);",
                  "        pm.environment.set('contract_agreement', JSON.stringify(agreement));",
                  "        console.log('✅ transfer_contract guardado:', agreement['@id']);",
                  "    } else {",
                  "        console.log('❌ No se encontró @id en la respuesta. Body (500 chars):');",
                  "        console.log(raw.substring(0, 500));",
                  "        pm.test('transfer_contract extraído', () => pm.expect.fail('No se pudo extraer @id del ContractAgreement'));",
                  "    }",
                  "})();"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "idsUser",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "passwordIdsUser",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"multipart\": \"{{multipart_type}}\",\n    \"Forward-To\": \"{{Forward-To}}\",\n    \"messageType\": \"ContractRequestMessage\",\n    \"requestedElement\": \"{{contract_artifact}}\",\n    \"contractId\": \"{{contract_id}}\",\n    \"contractProvider\": \"{{contract_provider}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{Proxy_Endpoint}}",
              "host": [
                "{{Proxy_Endpoint}}"
              ]
            },
            "description": "Negocia el contrato con el worker destino. El payload incluye el objeto ids:ContractRequest con los permisos extraídos del paso 1. La respuesta será el ContractAgreement — se guarda automáticamente en contract_agreement y transfer_contract."
          },
          "response": []
        },
        {
          "name": "4 - IDS: Contract Agreement Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Acuerdo procesado (MessageProcessedNotification)\", () => {",
                  "    const body = pm.response.text();",
                  "    pm.expect(body).to.satisfy(b =>",
                  "        b.includes(\"MessageProcessedNotification\") || b.includes(\"processed\") || b.length > 0",
                  "    );",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "idsUser",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "passwordIdsUser",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"multipart\": \"{{multipart_type}}\",\n    \"Forward-To\": \"{{Forward-To}}\",\n    \"messageType\": \"ContractAgreementMessage\",\n    \"requestedArtifact\": \"{{contract_artifact}}\",\n    \"transferContract\": \"{{transfer_contract}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{Proxy_Endpoint}}",
              "host": [
                "{{Proxy_Endpoint}}"
              ]
            },
            "description": "Confirma la aceptación del contrato. Envía el ContractAgreement recibido en el paso 3. El worker responderá con MessageProcessedNotificationMessage."
          },
          "response": []
        },
        {
          "name": "5 - IDS: Envío de algorithm.py al Worker (ArtifactRequest)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"algorithm.py + fl_config.json recibidos\", () => {",
                  "    const body = pm.response.text();",
                  "    pm.expect(body).to.satisfy(b =>",
                  "        b.includes(\"everything_received\") || b.includes(\"ArtifactResponse\")",
                  "    );",
                  "});",
                  "try {",
                  "    const json = pm.response.json();",
                  "    if (json.status === \"everything_received\") {",
                  "        console.log(\"✅ Coordinator:\", json.coordinator, \"— FL config:\", JSON.stringify(json.fl_config));",
                  "    }",
                  "} catch(e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "idsUser",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "passwordIdsUser",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"multipart\": \"{{multipart_type}}\",\n    \"Forward-To\": \"{{Forward-To}}\",\n    \"messageType\": \"ArtifactRequestMessage\",\n    \"requestedArtifact\": \"{{contract_artifact}}\",\n    \"transferContract\": \"{{transfer_contract}}\",\n    \"payload\": {\n        \"type\": \"fl_algorithm\",\n        \"filename\": \"algorithm.py\",\n        \"content\": \"{{algorithm_b64}}\",\n        \"config\": \"{{config_b64}}\"\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{Proxy_Endpoint}}",
              "host": [
                "{{Proxy_Endpoint}}"
              ]
            },
            "description": "PASO CRÍTICO: envía algorithm.py + fl_config.json (ambos en base64) al worker destino.\nEl worker se convierte en coordinator, guarda la configuración, la distribuye a los peers y arranca el FL.\n\n⚠️ ANTES de ejecutar:\n1. Rellena algorithm_b64:\n   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes('.\\ia-dataapp\\algorithm.py'))\n\n2. Rellena config_b64:\n   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes('.\\ia-dataapp\\fl_config.json'))\n\nEstructura de fl_config.json:\n{\n  \"rounds\": 5,\n  \"round_timeout\": 180,\n  \"min_workers\": 2,\n  \"epochs\": 3,\n  \"batch_size\": 32,\n  \"learning_rate\": 0.001,\n  \"test_split\": 0.2\n}"
          },
          "response": []
        },
        {
          "name": "6 - Verify: Coordinator activo con algorithm.py",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"Es coordinator y tiene algorithm.py\", () => {",
                  "    pm.expect(json.role).to.equal(\"coordinator\");",
                  "    pm.expect(json.algorithm_loaded).to.be.true;",
                  "    console.log(\"✅ Worker\", json.instance, \"| role:\", json.role, \"| algorithm_loaded:\", json.algorithm_loaded);",
                  "    console.log(\"   FL status:\", json.fl_status, \"| CSV:\", json.csv_selected);",
                  "    console.log(\"   Peers:\", json.peer_eccs);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://localhost:{{Coordinator_Port}}/status",
              "protocol": "https",
              "host": [
                "localhost"
              ],
              "port": "{{Coordinator_Port}}",
              "path": [
                "status"
              ]
            }
          },
          "description": "Verifica en un solo paso que el coordinator (worker-2) está activo, tiene el rol correcto y algorithm.py cargado y listo para arrancar el FL.",
          "response": []
        },
        {
          "name": "7 - FL: Arrancar entrenamiento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 202 Accepted\", () => pm.response.to.have.status(202));",
                  "pm.test(\"FL arrancado correctamente\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.equal(\"started\");",
                  "    console.log(\"✅ FL arrancado — coordinator:\", json.coordinator, \"| rondas:\", json.fl_rounds);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://localhost:{{Coordinator_Port}}/fl/start",
              "protocol": "https",
              "host": [
                "localhost"
              ],
              "port": "{{Coordinator_Port}}",
              "path": [
                "fl",
                "start"
              ]
            },
            "description": "Arranca el ciclo FL completo en el coordinator.\nLos parámetros (rounds, round_timeout, etc.) se leen automáticamente de fl_config.json\nrecibido en el paso 5. No es necesario pasar ningún parámetro en el body."
          },
          "description": "Arranca el ciclo FL. El coordinator distribuye algorithm.py a los peers vía IDS y lanza FedAvg.\n\nCambia {{Coordinator_Port}} en el environment para apuntar al worker correcto.",
          "response": []
        },
        {
          "name": "8 - Verify: Peers recibieron algorithm.py (workers 1, 2 y 3)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Este paso consulta /status del propio coordinator para ver si los peers",
                  "// están listados. Para verificar los otros workers individualmente,",
                  "// ejecuta este mismo paso cambiando el puerto en Coordinator_Port.",
                  "//",
                  "// Worker-1: 5001 | Worker-2: 5002 | Worker-3: 5003",
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"algorithm.py cargado en este worker\", () => {",
                  "    pm.expect(json.algorithm_loaded).to.be.true;",
                  "    console.log(\"✅ Worker\", json.instance, \"| role:\", json.role, \"| algorithm_loaded:\", json.algorithm_loaded);",
                  "    console.log(\"   Peers configurados:\", JSON.stringify(json.peer_eccs));",
                  "    if (json.fl_status !== 'idle') {",
                  "        console.log(\"✅ FL ya en marcha — status:\", json.fl_status);",
                  "    } else {",
                  "        console.log(\"⚠️  FL todavía idle en este worker — puede que la distribución aún esté en curso\");",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://localhost:{{Coordinator_Port}}/status",
              "protocol": "https",
              "host": [
                "localhost"
              ],
              "port": "{{Coordinator_Port}}",
              "path": [
                "status"
              ]
            }
          },
          "description": "Verifica que algorithm.py llegó correctamente a cada worker. Ejecutar una vez con cada puerto:\n  5001 → Worker-1\n  5002 → Worker-2 (coordinator)\n  5003 → Worker-3\n\nBusca algorithm_loaded: true en los 3 antes de seguir con el polling de /fl/status.",
          "response": []
        },
        {
          "name": "9 - Verify: FL arrancó y en curso (repetir hasta completed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"FL no está idle (arrancó correctamente)\", () => {",
                  "    pm.expect(json.status).to.not.equal(\"idle\");",
                  "    console.log(\"FL status:\", json.status, \"| ronda:\", json.current_round, \"/\", json.total_rounds);",
                  "});",
                  "pm.test(\"FL en curso o completado\", () => {",
                  "    pm.expect([\"running\",\"completed\",\"failed\",",
                  "               \"round_1\",\"round_2\",\"round_3\",\"round_4\",\"round_5\"]",
                  "    ).to.include(json.status);",
                  "});",
                  "if (json.status === \"completed\") {",
                  "    const last = json.history[json.history.length - 1];",
                  "    console.log(\"✅ FL completado —\", json.total_rounds, \"rondas\");",
                  "    console.log(\"   acc=\", last?.global_metrics?.accuracy, \"| auc=\", last?.global_metrics?.auc);",
                  "} else {",
                  "    console.log(\"FL status:\", json.status, \"— ronda\", json.current_round, \"/\", json.total_rounds);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://localhost:{{Coordinator_Port}}/fl/status",
              "protocol": "https",
              "host": [
                "localhost"
              ],
              "port": "{{Coordinator_Port}}",
              "path": [
                "fl",
                "status"
              ]
            }
          },
          "description": "Ejecutar justo tras arrancar FL para confirmar que no está idle, y repetir periódicamente hasta ver status=completed. Muestra ronda actual y métricas finales al completarse.",
          "response": []
        },
        {
          "name": "10 - FL: Resultados del Coordinator (historial completo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Historial disponible\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an(\"array\").with.length.above(0);",
                  "    console.log(\"Rondas en historial:\", json.length);",
                  "    json.forEach((r) => {",
                  "        console.log(`  Ronda ${r.round}: acc=${r.global_metrics?.accuracy} | auc=${r.global_metrics?.auc} | samples=${r.total_samples}`);",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://localhost:{{Coordinator_Port}}/fl/results",
              "protocol": "https",
              "host": [
                "localhost"
              ],
              "port": "{{Coordinator_Port}}",
              "path": [
                "fl",
                "results"
              ]
            }
          },
          "response": []
        },
        {
          "name": "11 - FL: Modelo global del Coordinator",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Modelo disponible con métricas\", () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.metrics).to.exist;",
                  "    pm.expect(json.weights_available).to.be.true;",
                  "    console.log(\"Ronda final:\", json.round);",
