# =============================================================================
# .gitignore — Proyecto FL IDS Workers (TFG)
# =============================================================================

# ── Variables de entorno y secretos ──────────────────────────────────────────
.env
_env
*.env
.env.*

# ── Certificados y keystores (generados en runtime o sensibles) ──────────────
certs/dataapp/
certs/cert.pem
certs/key.pem
certs/run.py
certs/server.p12
certs/ssl-server.jks
certs/truststoreEcc.jks
*.key
*.crt

# ── Datos de ejecución de los workers (FL + algoritmos envíados por IDS) ──────
ia-dataapp/data/worker*/algorithm.py
ia-dataapp/data/worker*/fl_config.json
ia-dataapp/data/worker*/output/
ia-dataapp/data/raw/phising_url_detection_dataset.csv
ia-dataapp/data/worker1/input/phising_url_detection_worker_1.csv

# ── Bases de Datos locales y Caches (Broker / Omejdn / Linter) ───────────────
*.db
*.sqlite
*.sqlite3
.pyre/

# ── Logs ─────────────────────────────────────────────────────────────────────
ia-dataapp/log/
*.log

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# ── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.sw?

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Postman exports temporales ───────────────────────────────────────────────
*_backup*.json

# ── DAPS ───────────────────────────────────────────────
omejdn/config/users.yaml