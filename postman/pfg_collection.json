              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Worker4 puede ver la self-description del coordinator (catálogo público)', () => {",
                  "    const raw = pm.response.text();",
                  "    pm.expect(raw).to.satisfy(b => b.includes('resourceCatalog') || b.includes('@type'));",
                  "    console.log('✅ Self-description recibida — el catálogo es público');",
                  "    console.log('   (worker4 puede VER que existe el recurso FL, pero no acceder a él)');",
                  "});",
                  "",
                  "// Extraer recurso FL para usarlo en el siguiente paso",
                  "(function() {",
                  "    const raw = pm.response.text();",
                  "    let sd = null;",
                  "    try { sd = JSON.parse(raw); } catch(e) {",
                  "        const blocks = raw.match(/\\{[\\s\\S]*\\}/g) || [];",
                  "        blocks.sort((a,b) => b.length - a.length);",
                  "        for (const b of blocks) { try { sd = JSON.parse(b); break; } catch(e) {} }",
                  "    }",
                  "    if (!sd) { console.log('⚠️  No se pudo parsear self-description'); return; }",
                  "    const resources = ((sd['ids:resourceCatalog'] || [{}])[0]['ids:offeredResource'] || []);",
                  "    const flRes = resources.find(r => {",
                  "        const title = ((r['ids:title'] || [{}])[0]['@value'] || '');",
                  "        return title.includes('FL Global Model') || (r['@id'] || '').includes('fl_model_coordinator');",
                  "    });",
                  "    if (flRes) {",
                  "        const contract = (flRes['ids:contractOffer'] || [{}])[0] || {};",
                  "        pm.environment.set('w4_fl_resource_id', flRes['@id']);",
                  "        pm.environment.set('w4_fl_contract_id', contract['@id'] || '');",
                  "        console.log('✅ Recurso FL encontrado:', flRes['@id']);",
                  "        console.log('   Contrato:', contract['@id'] || 'no encontrado');",
                  "    } else {",
                  "        console.log('⚠️  Recurso FL no encontrado — ¿FL completado?');",
                  "    }",
                  "})();"
                ]
              }
