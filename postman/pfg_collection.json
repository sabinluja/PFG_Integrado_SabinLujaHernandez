                  "pm.test('Contrato FL usa connector-restricted-policy con constraint de peers', () => {",
                  "    const contract = pm.response.json();",
                  "    pm.expect(contract).to.exist;",
                  "    console.log('Contrato ID:', contract['@id']);",
                  "",
                  "    const perms = contract['ids:permission'] || [];",
                  "    pm.expect(perms.length).to.be.above(0, 'El contrato no tiene permisos');",
                  "",
                  "    const perm = perms[0];",
                  "    const desc = ((perm['ids:description'] || [{}])[0]['@value'] || '');",
                  "    pm.expect(desc).to.equal('connector-restricted-policy',",
                  "        'La política debe ser connector-restricted-policy');",
                  "    console.log('✅ Política:', desc);",
                  "",
                  "    const constraints = perm['ids:constraint'] || [];",
                  "    pm.expect(constraints.length).to.be.above(0, 'Sin constraints — contrato no restringido');",
                  "",
                  "    const constraint = constraints[0];",
                  "    const operator = (constraint['ids:operator'] || {})['@id'] || '';",
                  "    pm.expect(operator).to.include('IN', 'El operador debe ser IN');",
                  "",
                  "    const allowed = (constraint['ids:rightOperand'] || []).map(v => v['@value'] || v['@id'] || v);",
                  "    pm.expect(allowed.length).to.be.above(0, 'Sin conectores permitidos en constraint');",
                  "    console.log('✅ Conectores autorizados:', allowed.join(', '));",
                  "",
                  "    const hasWorker4 = allowed.some(u => u.includes('worker4'));",
                  "    pm.expect(hasWorker4).to.be.false;",
                  "    console.log('✅ Worker4 NO está en la lista — correcto');",
                  "",
                  "    pm.environment.set('fl_model_allowed_uris', allowed.join(','));",
                  "});"
