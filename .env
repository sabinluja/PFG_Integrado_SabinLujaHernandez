# ---------------------------------------------------------------------------
# Ollama LLM — dataset recommendation (Local & Air-gapped)
# ---------------------------------------------------------------------------
LLM_ENDPOINT=http://ollama:11434/api/generate
LLM_MODEL=llama3.2

# CSV de referencia para el coordinator (por defecto)
COORDINATOR_CSV_REFERENCE=unsw_nb15_worker_2.csv

# ---------------------------------------------------------------------------
# CLEARING HOUSE — Notario IDS (audit & logging de transacciones IDS)
# ---------------------------------------------------------------------------
CLEARING_HOUSE_PORT=8095
CLEARING_HOUSE_URL=http://clearinghouse:8000
CLEARING_HOUSE_CONNECTOR_URI=http://w3id.org/engrd/connector/clearinghouse
CLEARING_HOUSE_ECC_URL=https://ecc-clearinghouse:8889/data
CLEARING_HOUSE_DEFAULT_ENDPOINT=https://ecc-clearinghouse:8449/api/ids/data
CLEARING_HOUSE_DAPS_KEYSTORE_NAME=clearinghouse-daps.p12
CLEARING_HOUSE_DAPS_KEYSTORE_PASSWORD=ids2024
CLEARING_HOUSE_DAPS_KEYSTORE_ALIAS=clearinghouse
CLEARING_HOUSE_CONNECTOR_UUID=4C:2D:93:F0:8A:0A:EC:76:21:C0:D4:C6:17:25:31:AB:B2:31:B0:CC:keyid:4C:2D:93:F0:8A:0A:EC:76:21:C0:D4:C6:17:25:31:AB:B2:31:B0:CC
