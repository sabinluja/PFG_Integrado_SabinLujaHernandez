                  "const eccHost = map[port] || 'ecc-worker2';",
                  "const eccUrl = `https://${eccHost}:8889/data`;",
                  "pm.environment.set('Worker4_ECC_Forward_To', eccUrl);",
                  "console.log('[pre] Worker4 apuntará al coordinator:', eccUrl);"
                ]
              }
