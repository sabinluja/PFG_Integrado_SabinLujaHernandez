COMPOSE_PROJECT_NAME=trueconnector

# DB AES PASSWORD
AES_SECRET_KEY=mySecretKey1234567890123456

# ---------------------------------------------------------------------------
# BROKER — apunta al Broker IDS local (ids-broker, levantado en docker-compose)
# En producción: https://broker.ids.isst.fraunhofer.de/infrastructure
# ---------------------------------------------------------------------------
BROKER_URL=https://broker-reverseproxy/infrastructure

# TLS
KEYSTORE_NAME=ssl-server.jks
KEY_PASSWORD=changeit
KEYSTORE_PASSWORD=changeit
ALIAS=execution-core-container

TRUSTORE_NAME=truststoreEcc.jks
TRUSTORE_PASSWORD=allpassword

# ---------------------------------------------------------------------------
# DAPS — token caching activado y fetch en arranque para Omejdn local
# Los ECCs apuntan a Omejdn a través de nginx (container "omejdn"):
#   application.dapsUrl     = https://omejdn/auth/token
#   application.dapsJWKSUrl = https://omejdn/auth/jwks.json
# (configurado en application-docker.properties, no aquí)
# ---------------------------------------------------------------------------
CACHE_TOKEN=true
FETCH_TOKEN_ON_STARTUP=true

MULTIPART_ECC=form
WS_ECC=false
IDSCP2=false

EXTRACT_PAYLOAD_FROM_RESPONSE=true
VALIDATE_SELF_DESCRIPTION=false

# Parámetros FL — usados por los 3 workers
FL_ROUNDS=5
ROUND_TIMEOUT=180

# ---------------------------------------------------------------------------
# WORKER 1
# ---------------------------------------------------------------------------
WORKER1_PORT=8090
WORKER1_MULTIPART_EDGE=form
WORKER1_DATA_APP_ENDPOINT=https://be-dataapp-worker1:8500/data
WORKER1_WS_EDGE=false
WORKER1_ISSUER_CONNECTOR_URI=http://w3id.org/engrd/connector/worker1
WORKER1_ECC_FIREWALL=true
# Keystore DAPS para worker1 — fichero P12 registrado en Omejdn
# Ruta relativa a ./certs/ (montado en /cert/ dentro del ECC)
WORKER1_DAPS_KEYSTORE_NAME=worker1-daps.jks
WORKER1_DAPS_KEYSTORE_PASSWORD=ids2024
WORKER1_DAPS_KEYSTORE_ALIAS=worker1

# ---------------------------------------------------------------------------
# WORKER 2
# ---------------------------------------------------------------------------
WORKER2_PORT=8092
WORKER2_MULTIPART_EDGE=form
WORKER2_DATA_APP_ENDPOINT=https://be-dataapp-worker2:8500/data
WORKER2_WS_EDGE=false
WORKER2_ISSUER_CONNECTOR_URI=http://w3id.org/engrd/connector/worker2
WORKER2_ECC_FIREWALL=true
WORKER2_DAPS_KEYSTORE_NAME=worker2-daps.jks
WORKER2_DAPS_KEYSTORE_PASSWORD=ids2024
WORKER2_DAPS_KEYSTORE_ALIAS=worker2

# ---------------------------------------------------------------------------
# WORKER 3
# ---------------------------------------------------------------------------
WORKER3_PORT=8093
WORKER3_MULTIPART_EDGE=form
WORKER3_DATA_APP_ENDPOINT=https://be-dataapp-worker3:8500/data
WORKER3_WS_EDGE=false
WORKER3_ISSUER_CONNECTOR_URI=http://w3id.org/engrd/connector/worker3
WORKER3_ECC_FIREWALL=true
WORKER3_DAPS_KEYSTORE_NAME=worker3-daps.jks
WORKER3_DAPS_KEYSTORE_PASSWORD=ids2024
WORKER3_DAPS_KEYSTORE_ALIAS=worker3

# ---------------------------------------------------------------------------
# WORKER 4 (sin acceso al modelo FL — conector IDS legítimo, rechazado en FL)
# ---------------------------------------------------------------------------
WORKER4_PORT=8094
WORKER4_MULTIPART_EDGE=form
WORKER4_DATA_APP_ENDPOINT=https://be-dataapp-worker4:8500/data
WORKER4_WS_EDGE=false
WORKER4_ISSUER_CONNECTOR_URI=http://w3id.org/engrd/connector/worker4
WORKER4_ECC_FIREWALL=true
WORKER4_DAPS_KEYSTORE_NAME=worker4-daps.jks
WORKER4_DAPS_KEYSTORE_PASSWORD=ids2024
WORKER4_DAPS_KEYSTORE_ALIAS=worker4