WORKER2_CONNECTOR_UUID=CE:40:92:FB:F6:2A:72:C9:5D:C4:14:FD:DE:DA:12:1C:D3:DB:10:EF:keyid:C4:76:D0:AA:CD:93:79:35:0F:EB:A7:64:60:90:A4:6B:B4:38:4D:33
